# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# 1. AIVEN CLOUD MYSQL (Active for Production / Vercel Live)
# Note: Ensure IP allowlist includes 0.0.0.0/0 in Aiven Console
DATABASE_URL="mysql://<AIVEN_USERNAME>:<AIVEN_PASSWORD>@<AIVEN_HOST>:<PORT>/defaultdb?ssl-mode=REQUIRED"

# 2. LOCAL MYSQL (Uncomment this line below if working offline)
# DATABASE_URL="mysql://root:YOUR_LOCAL_PASSWORD@localhost:3306/loop_db"


# ==========================================
# GOOGLE AI ENDPOINT KEY
# ==========================================
# Your official Google Gemini Production API Key
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"


# ==========================================
# NEXT.JS AUTH SECRET
# ==========================================
# Secure random string to encrypt cookies and sessions
NEXTAUTH_SECRET="your-secure-random-secret-key"